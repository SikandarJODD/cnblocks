on>\r\n\t\t\t\t\t\t</th>\r\n\t\t\t\t\t\t<th class=\"space-y-3\">\r\n\t\t\t\t\t\t\t<span class=\"block\">Startup</span>\r\n\t\t\t\t\t\t\t<Button variant=\"neutral\">Get Started</Button>\r\n\t\t\t\t\t\t</th>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</thead>\r\n\t\t\t\t<tbody>\r\n\t\t\t\t\t<tr class=\"*:py-4\">\r\n\t\t\t\t\t\t<td class=\"flex items-center gap-2 font-medium\">\r\n\t\t\t\t\t\t\t<Star class=\"size-4\" />\r\n\t\t\t\t\t\t\t<span>Features</span>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t<td class=\"border-none px-4\"></td>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t{#each tableData.slice(-4) as row}\r\n\t\t\t\t\t\t<tr class=\"*:border-b *:py-4\">\r\n\t\t\t\t\t\t\t<td class=\"text-muted-foreground\">{row.feature}</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.free === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t{row.free}\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.pro === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t{row.pro}\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.startup === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t{row.startup}\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t{/each}\r\n\t\t\t\t\t<tr class=\"*:pt-8 *:pb-4\">\r\n\t\t\t\t\t\t<td class=\"flex items-center gap-2 font-medium\">\r\n\t\t\t\t\t\t\t<Sparkles class=\"size-4\" />\r\n\t\t\t\t\t\t\t<span>AI Models</span>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t<td class=\"border-none bg-muted px-4 dark:bg-transparent\"></td>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t{#each tableData as row}\r\n\t\t\t\t\t\t<tr class=\"*:border-b *:py-4\">\r\n\t\t\t\t\t\t\t<td class=\"text-muted-foreground\">{row.feature}</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.free === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.pro === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t{row.pro}\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t{#if row.startup === true}\r\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\r\n\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t{row.startup}\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t{/each}\r\n\t\t\t\t</tbody>\r\n\t\t\t</table>\r\n\t\t</div>\r\n\t</div>\r\n</section>\r\n",
