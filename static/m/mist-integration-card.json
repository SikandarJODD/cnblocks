{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "mist-integration-card",
  "type": "mintegration",
  "description": "Mist-style integration logo card",
  "registryDependencies": [
    "button",
    "card"
  ],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
      "name": "@lucide/svelte",
      "version": "^0.561.0"
    },
    {
      "ecosystem": "js",
      "name": "svelte",
      "version": "^5.23.0"
    }
  ],
  "files": [
    {
      "path": "integration-card.svelte",
      "type": "mintegration",
      "target": "integration-card.svelte",
      "content": "<script lang=\"ts\">\r\n  import Button from \"$lib/components/ui/button/button.svelte\";\r\n  import Card from \"$lib/components/ui/card/card.svelte\";\r\n  import ChevronRight from \"@lucide/svelte/icons/chevron-right\";\r\n  import type { Snippet } from \"svelte\";\r\n\r\n  type IntegrationCardProps = {\r\n    title: string;\r\n    description: string;\r\n    children?: Snippet;\r\n  };\r\n  let { children, title, description }: IntegrationCardProps = $props();\r\n</script>\r\n\r\n<Card variant=\"soft\" class=\"p-6\">\r\n  <div class=\"relative\">\r\n    <div class=\"*:size-10\">{@render children?.()}</div>\r\n    <div class=\"mt-6 space-y-1.5\">\r\n      <h3 class=\"text-lg font-semibold\">{title}</h3>\r\n      <p class=\"text-muted-foreground line-clamp-2\">{description}</p>\r\n    </div>\r\n  </div>\r\n</Card>\r\n",
      "registryDependencies": [],
      "dependencies": [],
      "devDependencies": []
    }
  ]
}
