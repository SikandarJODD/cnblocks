default'>Get Started</Button>\r\n            </th>\r\n            <th class=\"space-y-3\">\r\n              <span class=\"block\">Startup</span>\r\n              <Button variant=\"neutral\">Get Started</Button>\r\n            </th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          <tr class=\"*:py-4\">\r\n            <td class=\"flex items-center gap-2 font-medium\">\r\n              <Star class=\"size-4\" />\r\n              <span>Features</span>\r\n            </td>\r\n            <td></td>\r\n            <td class=\"border-none px-4\"></td>\r\n            <td></td>\r\n          </tr>\r\n          {#each tableData.slice(-4) as row}\r\n            <tr class=\"*:border-b *:py-4\">\r\n              <td class=\"text-muted-foreground\">{row.feature}</td>\r\n              <td>\r\n                {#if row.free === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {:else}\r\n                  {row.free}\r\n                {/if}\r\n              </td>\r\n              <td>\r\n                {#if row.pro === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {:else}\r\n                  {row.pro}\r\n                {/if}\r\n              </td>\r\n              <td>\r\n                {#if row.startup === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {:else}\r\n                  {row.startup}\r\n                {/if}\r\n              </td>\r\n            </tr>\r\n          {/each}\r\n          <tr class=\"*:pb-4 *:pt-8\">\r\n            <td class=\"flex items-center gap-2 font-medium\">\r\n              <Sparkles class=\"size-4\" />\r\n              <span>AI Models</span>\r\n            </td>\r\n            <td></td>\r\n            <td class=\"bg-muted dark:bg-transparent border-none px-4\"></td>\r\n            <td></td>\r\n          </tr>\r\n          {#each tableData as row}\r\n            <tr class=\"*:border-b *:py-4\">\r\n              <td class=\"text-muted-foreground\">{row.feature}</td>\r\n              <td>\r\n                {#if row.free === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {/if}\r\n              </td>\r\n              <td>\r\n                {#if row.pro === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {:else}\r\n                  {row.pro}\r\n                {/if}\r\n              </td>\r\n              <td>\r\n                {#if row.startup === true}\r\n                  <Check class=\"text-primary size-3\" strokeWidth={3.5} />\r\n                {:else}\r\n                  {row.startup}\r\n                {/if}\r\n              </td>\r\n            </tr>\r\n          {/each}\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n  </div>\r\n</section>\r\n",
