border-t py-6 md:grid-cols-4\"\r\n      >\r\n        {#each members as member, index}\r\n          <div>\r\n            <div\r\n              class=\"bg-background size-20 rounded-full border p-0.5 shadow shadow-zinc-950/5\"\r\n            >\r\n              <img\r\n                class=\"aspect-square rounded-full object-cover\"\r\n                src={member.avatar}\r\n                alt={member.name}\r\n                height=\"460\"\r\n                width=\"460\"\r\n                loading=\"lazy\"\r\n              />\r\n            </div>\r\n            <span class=\"mt-2 block text-sm\">{member.name}</span>\r\n            <span class=\"text-muted-foreground block text-xs\"\r\n              >{member.role}</span\r\n            >\r\n          </div>\r\n        {/each}\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"mt-6\">\r\n      <h3 class=\"mb-6 text-lg font-medium\">Marketing</h3>\r\n      <div\r\n        data-rounded=\"full\"\r\n        class=\"grid grid-cols-2 gap-4 border-t py-6 md:grid-cols-4\"\r\n      >\r\n        {#each members as member, index}\r\n          <div>\r\n            <div\r\n              class=\"bg-background size-20 rounded-full border p-0.5 shadow shadow-zinc-950/5\"\r\n            >\r\n              <img\r\n                class=\"aspect-square rounded-full object-cover\"\r\n                src={member.avatar}\r\n                alt={member.name}\r\n                height=\"460\"\r\n                width=\"460\"\r\n                loading=\"lazy\"\r\n              />\r\n            </div>\r\n            <span class=\"mt-2 block text-sm\">{member.name}</span>\r\n            <span class=\"text-muted-foreground block text-xs\"\r\n              >{member.role}</span\r\n            >\r\n          </div>\r\n        {/each}\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n",
