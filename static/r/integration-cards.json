    {
      "path": "card/integration-card.svelte",
      "type": "integration",
      "target": "card/integration-card.svelte",
      "content": "<script lang=\"ts\">\r\n  import Button from \"$lib/components/ui/button/button.svelte\";\r\n  import Card from \"$lib/components/ui/card/card.svelte\";\r\n  import ChevronRight from \"@lucide/svelte/icons/chevron-right\";\r\n  import type { Snippet } from \"svelte\";\r\n\r\n  type IntegrationCardProps = {\r\n    title: string;\r\n    description: string;\r\n    link?: string;\r\n    children?: Snippet;\r\n  };\r\n  let {\r\n    children,\r\n    title,\r\n    description,\r\n    link = \"https://github.com/SikandarJODD/cnblocks\",\r\n  }: IntegrationCardProps = $props();\r\n</script>\r\n\r\n<Card class=\"p-6\">\r\n  <div class=\"relative\">\r\n    <div class=\"*:size-10\">{@render children?.()}</div>\r\n    <div class=\"space-y-2 py-6\">\r\n      <h3 class=\"text-base font-medium\">{title}</h3>\r\n      <p class=\"text-muted-foreground line-clamp-2 text-sm\">{description}</p>\r\n    </div>\r\n\r\n    <div class=\"flex gap-3 border-t border-dashed pt-6\">\r\n      <Button\r\n        variant=\"secondary\"\r\n        size=\"sm\"\r\n        class=\"gap-1 pr-2 shadow-none\"\r\n        href={link}\r\n      >\r\n        Learn More\r\n        <ChevronRight class=\"ml-0 !size-3.5 opacity-50\" />\r\n      </Button>\r\n    </div>\r\n  </div>\r\n</Card>\r\n",
      "registryDependencies": [],
      "dependencies": [],
      "devDependencies": []
    },
    {
