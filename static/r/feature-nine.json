ed-(--radius) mb-1 ml-auto w-3/5 bg-blue-600 p-3 text-xs text-white\"\r\n          >\r\n            Molestiae numquam debitis et ullam distinctio provident nobis\r\n            repudiandae deleniti necessitatibus.\r\n          </div>\r\n          <span class=\"text-muted-foreground block text-right text-xs\">Now</span\r\n          >\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <!-- <div class=\"col-span-full border-y p-12\">\r\n          <p class=\"text-center text-4xl font-semibold lg:text-7xl\">99.99% Uptime</p>\r\n      </div> -->\r\n  </div>\r\n</section>\r\n\r\n{#snippet Map()}\r\n  {@const viewBox = \"0 0 120 60\"}\r\n\r\n  <svg\r\n    {viewBox}\r\n    xmlns=\"http://www.w3.org/2000/svg\"\r\n    style=\"background-color: {svgOptions.backgroundColor};\"\r\n  >\r\n    {#each points as point, index}\r\n      <circle\r\n        cx={point.x}\r\n        cy={point.y}\r\n        r={svgOptions.radius}\r\n        fill={svgOptions.color}\r\n      />\r\n    {/each}\r\n  </svg>\r\n{/snippet}\r\n",
