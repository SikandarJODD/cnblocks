{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "vhelper-theme-switcher",
  "type": "vhelper",
  "description": "Internal Veil footer theme switcher helper.",
  "registryDependencies": [],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
      "name": "mode-watcher",
      "version": "^1.0.6"
    },
    {
      "ecosystem": "js",
      "name": "@lucide/svelte",
      "version": "^0.561.0"
    },
    {
      "ecosystem": "js",
      "name": "svelte",
      "version": "^5.23.0"
    }
  ],
  "files": [
    {
      "path": "theme-switcher.svelte",
      "type": "vhelper",
      "target": "theme-switcher.svelte",
      "content": "<script lang=\"ts\">\n  import { Button } from \"$lib/components/ui/veil/button\";\n  import { mode, setTheme } from \"mode-watcher\";\n  import { Monitor, Moon, Sun } from \"@lucide/svelte\";\n  import { fade, fly, scale } from \"svelte/transition\";\n\n  type ThemeOption = \"system\" | \"light\" | \"dark\";\n\n  let hoveredTheme = $state<ThemeOption | null>(null);\n\n  const selectedTheme = $derived.by<ThemeOption>(() => {\n    const current = mode.current;\n    return current === \"light\" || current === \"dark\" || current === \"system\"\n      ? current\n      : \"system\";\n  });\n\n  const activeTheme = $derived(hoveredTheme ?? selectedTheme);\n\n  const tooltipLabel = $derived.by(() => {\n    switch (activeTheme) {\n      case \"light\":\n        return \"Switch to light theme\";\n      case \"dark\":\n        return \"Switch to dark theme\";\n      case \"system\":\n      default:\n        return \"Switch to system theme\";\n    }\n  });\n\n  function isActive(theme: ThemeOption): boolean {\n    return activeTheme === theme;\n  }\n\n  function isSelected(theme: ThemeOption): boolean {\n    return selectedTheme === theme;\n  }\n</script>\n\n<div class=\"w-fit\">\n  <div class=\"-ml-2 mb-2 flex\">\n    <div class=\"relative\">\n      <Button\n        size=\"icon\"\n        variant=\"ghost\"\n        aria-label=\"switch to system theme\"\n        aria-pressed={isSelected(\"system\")}\n        class={isSelected(\"system\") ? \"text-foreground\" : \"\"}\n        onmouseenter={() => (hoveredTheme = \"system\")}\n        onmouseleave={() => (hoveredTheme = null)}\n        onfocus={() => (hoveredTheme = \"system\")}\n        onblur={() => (hoveredTheme = null)}\n        onclick={() => setTheme(\"system\")}\n      >\n        <Monitor />\n      </Button>\n      {#if isActive(\"system\")}\n        <span\n          in:scale={{ start: 0.8, duration: 120 }}\n          out:scale={{ start: 1, duration: 120 }}\n          class=\"bg-foreground absolute -bottom-0.5 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full\"\n        ></span>\n      {/if}\n    </div>\n\n    <div class=\"relative\">\n      <Button\n        size=\"icon\"\n        variant=\"ghost\"\n        aria-label=\"switch to light theme\"\n        aria-pressed={isSelected(\"light\")}\n        class={isSelected(\"light\") ? \"text-foreground\" : \"\"}\n        onmouseenter={() => (hoveredTheme = \"light\")}\n        onmouseleave={() => (hoveredTheme = null)}\n        onfocus={() => (hoveredTheme = \"light\")}\n        onblur={() => (hoveredTheme = null)}\n        onclick={() => setTheme(\"light\")}\n      >\n        <Sun />\n      </Button>\n      {#if isActive(\"light\")}\n        <span\n          in:scale={{ start: 0.8, duration: 120 }}\n          out:scale={{ start: 1, duration: 120 }}\n          class=\"bg-foreground absolute -bottom-0.5 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full\"\n        ></span>\n      {/if}\n    </div>\n\n    <div class=\"relative\">\n      <Button\n        size=\"icon\"\n        variant=\"ghost\"\n        aria-label=\"switch to dark theme\"\n        aria-pressed={isSelected(\"dark\")}\n        class={isSelected(\"dark\") ? \"text-foreground\" : \"\"}\n        onmouseenter={() => (hoveredTheme = \"dark\")}\n        onmouseleave={() => (hoveredTheme = null)}\n        onfocus={() => (hoveredTheme = \"dark\")}\n        onblur={() => (hoveredTheme = null)}\n        onclick={() => setTheme(\"dark\")}\n      >\n        <Moon />\n      </Button>\n      {#if isActive(\"dark\")}\n        <span\n          in:scale={{ start: 0.8, duration: 120 }}\n          out:scale={{ start: 1, duration: 120 }}\n          class=\"bg-foreground absolute -bottom-0.5 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full\"\n        ></span>\n      {/if}\n    </div>\n  </div>\n\n  {#if hoveredTheme}\n    <div\n      aria-live=\"polite\"\n      class=\"text-muted-foreground w-fit text-xs leading-none\"\n      in:fade={{ duration: 150 }}\n      out:fade={{ duration: 120 }}\n    >\n      <span in:fly={{ y: 3, duration: 150 }} out:fly={{ y: -2, duration: 120 }}>\n        {tooltipLabel}\n      </span>\n    </div>\n  {/if}\n</div>\n",
      "registryDependencies": [],
      "dependencies": [],
      "devDependencies": []
    }
  ]
}
