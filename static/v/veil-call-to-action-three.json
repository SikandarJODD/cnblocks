{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "veil-call-to-action-three",
  "type": "vcta",
  "description": "Veil Call To Action component, variant Three.",
  "registryDependencies": [],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
      "name": "@lucide/svelte",
      "version": "^0.561.0"
