	"files": [
		{
			"content": "<script lang=\"ts\">\r\n\timport { Button } from \"$COMPONENTS$/ui/veil/button\";\r\n\timport { Card } from \"$COMPONENTS$/ui/veil/card\";\r\n\timport { Input } from \"$COMPONENTS$/ui/veil/input\";\r\n\timport { Label } from \"$COMPONENTS$/ui/label\";\r\n\timport * as Select from \"$COMPONENTS$/ui/select\";\r\n\timport { Textarea } from \"$COMPONENTS$/ui/veil/textarea\";\r\n</script>\r\n\r\n<section class=\"@container bg-background py-24\">\r\n\t<div class=\"mx-auto max-w-2xl px-6\">\r\n\t\t<div class=\"text-center\">\r\n\t\t\t<h1 class=\"font-serif text-4xl font-medium text-balance sm:text-5xl\">Contact Sales</h1>\r\n\t\t\t<p class=\"mx-auto mt-4 max-w-md text-balance text-muted-foreground\">\r\n\t\t\t\tReady to get started? Our team will help you find the right plan for your business.\r\n\t\t\t</p>\r\n\t\t</div>\r\n\r\n\t\t<Card variant=\"outline\" class=\"mt-12 p-8\">\r\n\t\t\t<form action=\"\" class=\"space-y-5\">\r\n\t\t\t\t<div class=\"grid gap-4 @md:grid-cols-2\">\r\n\t\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t\t<Label for=\"firstName\" class=\"text-sm\">First name</Label>\r\n\t\t\t\t\t\t<Input\r\n\t\t\t\t\t\t\ttype=\"text\"\r\n\t\t\t\t\t\t\tid=\"firstName\"\r\n\t\t\t\t\t\t\tname=\"firstName\"\r\n\t\t\t\t\t\t\tplaceholder=\"John\"\r\n\t\t\t\t\t\t\trequired\r\n\t\t\t\t\t\t/>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t\t<Label for=\"lastName\" class=\"text-sm\">Last name</Label>\r\n\t\t\t\t\t\t<Input\r\n\t\t\t\t\t\t\ttype=\"text\"\r\n\t\t\t\t\t\t\tid=\"lastName\"\r\n\t\t\t\t\t\t\tname=\"lastName\"\r\n\t\t\t\t\t\t\tplaceholder=\"Doe\"\r\n\t\t\t\t\t\t\trequired\r\n\t\t\t\t\t\t/>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t<Label for=\"email\" class=\"text-sm\">Work email</Label>\r\n\t\t\t\t\t<Input\r\n\t\t\t\t\t\ttype=\"email\"\r\n\t\t\t\t\t\tid=\"email\"\r\n\t\t\t\t\t\tname=\"email\"\r\n\t\t\t\t\t\tplaceholder=\"you@company.com\"\r\n\t\t\t\t\t\trequired\r\n\t\t\t\t\t/>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t<Label for=\"company\" class=\"text-sm\">Company</Label>\r\n\t\t\t\t\t<Input type=\"text\" id=\"company\" name=\"company\" placeholder=\"Acme Inc.\" />\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"grid gap-4 @md:grid-cols-2\">\r\n\t\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t\t<Label for=\"size\" class=\"text-sm\">Company size</Label>\r\n\t\t\t\t\t\t<Select.Root type=\"single\">\r\n\t\t\t\t\t\t\t<Select.Trigger\r\n\t\t\t\t\t\t\t\tclass=\"h-8 bg-card shadow-none ring-input focus-visible:ring-ring/15 dark:bg-transparent\"\r\n\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\tSelect\r\n\t\t\t\t\t\t\t</Select.Trigger>\r\n\t\t\t\t\t\t\t<Select.Content\r\n\t\t\t\t\t\t\t\tclass=\"rounded-xl border-transparent ring-1 ring-border\"\r\n\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"1-10\">1-10 employees</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"11-50\">11-50 employees</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"51-200\">51-200 employees</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"201-500\">201-500 employees</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"500+\">500+ employees</Select.Item>\r\n\t\t\t\t\t\t\t</Select.Content>\r\n\t\t\t\t\t\t</Select.Root>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t\t<Label for=\"interest\" class=\"text-sm\">Interest</Label>\r\n\t\t\t\t\t\t<Select.Root type=\"single\">\r\n\t\t\t\t\t\t\t<Select.Trigger\r\n\t\t\t\t\t\t\t\tclass=\"h-8 bg-card shadow-none ring-input focus-visible:ring-ring/15 dark:bg-transparent\"\r\n\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\tSelect\r\n\t\t\t\t\t\t\t</Select.Trigger>\r\n\t\t\t\t\t\t\t<Select.Content\r\n\t\t\t\t\t\t\t\tclass=\"rounded-xl border-transparent ring-1 ring-border\"\r\n\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"pricing\">Pricing</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"demo\">Product demo</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"partnership\">Partnership</Select.Item>\r\n\t\t\t\t\t\t\t\t<Select.Item value=\"other\">Other</Select.Item>\r\n\t\t\t\t\t\t\t</Select.Content>\r\n\t\t\t\t\t\t</Select.Root>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"space-y-2\">\r\n\t\t\t\t\t<Label for=\"message\" class=\"text-sm\">Message</Label>\r\n\t\t\t\t\t<Textarea\r\n\t\t\t\t\t\tid=\"message\"\r\n\t\t\t\t\t\tname=\"message\"\r\n\t\t\t\t\t\trows={5}\r\n\t\t\t\t\t\tplaceholder=\"Tell us about your needs...\"\r\n\t\t\t\t\t\tclass=\"min-h-28\"\r\n\t\t\t\t\t/>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<Button class=\"w-full\" type=\"submit\">Submit</Button>\r\n\t\t\t</form>\r\n\t\t</Card>\r\n\r\n\t\t<p class=\"mt-6 text-center text-sm text-muted-foreground\">\r\n\t\t\tBy submitting, you agree to our\r\n\t\t\t<a href=\"/\" class=\"text-foreground underline\">Privacy Policy</a>\r\n\t\t</p>\r\n\t</div>\r\n</section>\r\n",
			"type": "registry:component",
			"target": "veil/contact/contact-two.svelte"
		}
	]
