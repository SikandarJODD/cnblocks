{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "veil-comparator-three",
  "type": "vcomparator",
  "description": "Veil Comparator component, variant Three.",
  "registryDependencies": [],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
