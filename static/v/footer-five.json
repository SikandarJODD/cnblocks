			"content": "<script lang=\"ts\">\r\n\timport Logo from \"$COMPONENTS$/web/Logo.svelte\";\r\n\timport ThemeSwitcher from \"./theme-switcher.svelte\";\r\n\r\n\ttype LinkItem = { label: string; href: string };\r\n\r\n\tconst links: LinkItem[] = [\r\n\t\t{ label: \"Features\", href: \"#\" },\r\n\t\t{ label: \"Pricing\", href: \"#\" },\r\n\t\t{ label: \"About\", href: \"#\" },\r\n\t\t{ label: \"Blog\", href: \"#\" },\r\n\t\t{ label: \"Contact\", href: \"#\" },\r\n\t];\r\n\r\n\tconst year = new Date().getFullYear();\r\n</script>\r\n\r\n<footer class=\"@container bg-background py-12\">\r\n\t<div class=\"mx-auto max-w-2xl px-6\">\r\n\t\t<div class=\"flex flex-col\">\r\n\t\t\t<a\r\n\t\t\t\thref=\"/\"\r\n\t\t\t\taria-label=\"go home\"\r\n\t\t\t\tclass=\"-ml-1.5 flex size-8 rounded-lg *:m-auto hover:bg-foreground/5\"\r\n\t\t\t>\r\n\t\t\t\t<Logo class=\"w-fit\" />\r\n\t\t\t</a>\r\n\t\t\t<nav class=\"my-8 flex flex-wrap gap-x-8 gap-y-2\">\r\n\t\t\t\t{#each links as link (link.label)}\r\n\t\t\t\t\t<a\r\n\t\t\t\t\t\thref={link.href}\r\n\t\t\t\t\t\tclass=\"text-sm text-muted-foreground transition-colors hover:text-foreground\"\r\n\t\t\t\t\t>\r\n\t\t\t\t\t\t{link.label}\r\n\t\t\t\t\t</a>\r\n\t\t\t\t{/each}\r\n\t\t\t</nav>\r\n\r\n\t\t\t<ThemeSwitcher />\r\n\r\n\t\t\t<p class=\"mt-2 border-t pt-6 text-sm text-muted-foreground\">&copy; {year} Veil.</p>\r\n\t\t</div>\r\n\t</div>\r\n</footer>\r\n",
			"type": "registry:component",
			"target": "veil/footer/footer-five.svelte"
		}
	]
