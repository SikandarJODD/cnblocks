  "description": "Veil Call To Action component, variant One.",
  "registryDependencies": [],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
      "name": "@lucide/svelte",
      "version": "^0.561.0"
    }
  ],
  "files": [
    {
      "path": "call-to-action-one.svelte",
      "type": "vcta",
      "target": "call-to-action-one.svelte",
      "content": "<script lang=\"ts\">\n  import { Button } from \"$lib/components/ui/veil/button\";\n  import { ChevronRight } from \"@lucide/svelte\";\n\n  type Props = {\n    title?: string;\n    description?: string;\n    primaryLabel?: string;\n    primaryHref?: string;\n    secondaryLabel?: string;\n    secondaryHref?: string;\n  };\n\n  let {\n    title = \"Ready to Get Started?\",\n    description = \"Join thousands of teams already using our platform to build better products faster.\",\n    primaryLabel = \"Start Free Trial\",\n    primaryHref = \"#link\",\n    secondaryLabel = \"Talk to Sales\",\n    secondaryHref = \"#link\",\n  }: Props = $props();\n</script>\n\n<section class=\"bg-background @container py-24\">\n  <div class=\"mx-auto max-w-2xl px-6\">\n    <div class=\"text-center\">\n      <h2 class=\"text-balance font-serif text-4xl font-medium\">{title}</h2>\n      <p class=\"text-muted-foreground mx-auto mt-4 max-w-md text-balance\">\n        {description}\n      </p>\n      <div class=\"mt-6 flex flex-wrap justify-center gap-3\">\n        <Button href={primaryHref} class=\"pr-1.5\">\n          <span>{primaryLabel}</span>\n          <ChevronRight class=\"opacity-50\" />\n        </Button>\n        <Button variant=\"secondary\" href={secondaryHref}>\n          {secondaryLabel}\n        </Button>\n      </div>\n    </div>\n  </div>\n</section>\n",
      "registryDependencies": [],
      "dependencies": [],
      "devDependencies": []
    }
  ]
