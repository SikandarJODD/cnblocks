{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "comparator-three",
	"type": "registry:block",
	"description": "Veil Comparator component, variant Three.",
	"devDependencies": [
		"@lucide/svelte"
	],
	"registryDependencies": [
		"button",
		"card"
	],
	"files": [
		{
			"content": "<script lang=\"ts\">\r\n\timport Check from \"@lucide/svelte/icons/check\";\r\n\timport Minus from \"@lucide/svelte/icons/minus\";\r\n\timport { Button } from \"$COMPONENTS$/ui/veil/button\";\r\n\timport { Card } from \"$COMPONENTS$/ui/veil/card\";\r\n\r\n\ttype FeatureKey = \"integrations\" | \"apiCalls\" | \"support\" | \"analytics\" | \"webhooks\" | \"sso\";\r\n\r\n\ttype PlanFeatureValues = Record<FeatureKey, boolean | string>;\r\n\r\n\ttype Plan = {\r\n\t\tname: string;\r\n\t\tprice: string;\r\n\t\tperiod: string;\r\n\t\tdescription: string;\r\n\t\tcta: string;\r\n\t\thighlighted?: boolean;\r\n\t\tfeatures: PlanFeatureValues;\r\n\t};\r\n\r\n\tconst plans: Plan[] = [\r\n\t\t{\r\n\t\t\tname: \"Starter\",\r\n\t\t\tprice: \"$0\",\r\n\t\t\tperiod: \"/month\",\r\n\t\t\tdescription: \"For individuals and small projects\",\r\n\t\t\tcta: \"Get Started\",\r\n\t\t\tfeatures: {\r\n\t\t\t\tintegrations: \"3\",\r\n\t\t\t\tapiCalls: \"1,000/mo\",\r\n\t\t\t\tsupport: \"Community\",\r\n\t\t\t\tanalytics: false,\r\n\t\t\t\twebhooks: false,\r\n\t\t\t\tsso: false,\r\n\t\t\t},\r\n\t\t},\r\n\t\t{\r\n\t\t\tname: \"Pro\",\r\n\t\t\tprice: \"$29\",\r\n\t\t\tperiod: \"/month\",\r\n\t\t\tdescription: \"For growing teams\",\r\n\t\t\tcta: \"Start Free Trial\",\r\n\t\t\thighlighted: true,\r\n\t\t\tfeatures: {\r\n\t\t\t\tintegrations: \"Unlimited\",\r\n\t\t\t\tapiCalls: \"100,000/mo\",\r\n\t\t\t\tsupport: \"Priority\",\r\n\t\t\t\tanalytics: true,\r\n\t\t\t\twebhooks: true,\r\n\t\t\t\tsso: false,\r\n\t\t\t},\r\n\t\t},\r\n\t\t{\r\n\t\t\tname: \"Enterprise\",\r\n\t\t\tprice: \"Custom\",\r\n\t\t\tperiod: \"\",\r\n\t\t\tdescription: \"For large organizations\",\r\n\t\t\tcta: \"Contact Sales\",\r\n\t\t\tfeatures: {\r\n\t\t\t\tintegrations: \"Unlimited\",\r\n\t\t\t\tapiCalls: \"Unlimited\",\r\n\t\t\t\tsupport: \"Dedicated\",\r\n\t\t\t\tanalytics: true,\r\n\t\t\t\twebhooks: true,\r\n\t\t\t\tsso: true,\r\n\t\t\t},\r\n\t\t},\r\n\t];\r\n\r\n\tconst featureLabels: Record<FeatureKey, string> = {\r\n\t\tintegrations: \"Integrations\",\r\n\t\tapiCalls: \"API Calls\",\r\n\t\tsupport: \"Support\",\r\n\t\tanalytics: \"Analytics\",\r\n\t\twebhooks: \"Custom Webhooks\",\r\n\t\tsso: \"SSO / SAML\",\r\n\t};\r\n\r\n\tconst featureKeys: FeatureKey[] = [\r\n\t\t\"integrations\",\r\n\t\t\"apiCalls\",\r\n\t\t\"support\",\r\n\t\t\"analytics\",\r\n\t\t\"webhooks\",\r\n\t\t\"sso\",\r\n\t];\r\n</script>\r\n\r\n<section class=\"@container bg-background py-24\">\r\n\t<div class=\"mx-auto max-w-2xl px-6\">\r\n\t\t<div class=\"text-center\">\r\n\t\t\t<h2 class=\"font-serif text-4xl font-medium text-balance\">Choose Your Plan</h2>\r\n\t\t\t<p class=\"mx-auto mt-4 max-w-md text-balance text-muted-foreground\">\r\n\t\t\t\tStart free and scale as you grow.\r\n\t\t\t</p>\r\n\t\t</div>\r\n\t\t<div class=\"mt-12 space-y-4\">\r\n\t\t\t{#each plans as plan (plan.name)}\r\n\t\t\t\t<Card\r\n\t\t\t\t\tvariant={plan.highlighted ? \"default\" : \"mixed\"}\r\n\t\t\t\t\tclass={`p-6 ${plan.highlighted ? \"ring-primary\" : \"\"}`}\r\n\t\t\t\t>\r\n\t\t\t\t\t<div\r\n\t\t\t\t\t\tclass=\"flex flex-col gap-6 @lg:flex-row @lg:items-start @lg:justify-between\"\r\n\t\t\t\t\t>\r\n\t\t\t\t\t\t<div class=\"@lg:max-w-xs\">\r\n\t\t\t\t\t\t\t<h3 class=\"font-medium text-foreground\">{plan.name}</h3>\r\n\t\t\t\t\t\t\t<p class=\"mt-1 text-sm text-muted-foreground\">{plan.description}</p>\r\n\t\t\t\t\t\t\t<div class=\"mt-4\">\r\n\t\t\t\t\t\t\t\t<span class=\"font-serif text-3xl font-medium\">{plan.price}</span>\r\n\t\t\t\t\t\t\t\t{#if plan.period}\r\n\t\t\t\t\t\t\t\t\t<span class=\"text-muted-foreground\">{plan.period}</span>\r\n\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<Button\r\n\t\t\t\t\t\t\t\thref=\"#link\"\r\n\t\t\t\t\t\t\t\tvariant={plan.highlighted ? \"default\" : \"outline\"}\r\n\t\t\t\t\t\t\t\tsize=\"sm\"\r\n\t\t\t\t\t\t\t\tclass=\"mt-4\"\r\n\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t{plan.cta}\r\n\t\t\t\t\t\t\t</Button>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"w-full shrink-0 @lg:w-64\">\r\n\t\t\t\t\t\t\t{#each featureKeys as featureKey (featureKey)}\r\n\t\t\t\t\t\t\t\t{@const value = plan.features[featureKey]}\r\n\t\t\t\t\t\t\t\t<div\r\n\t\t\t\t\t\t\t\t\tclass=\"flex items-center justify-between border-b py-3 text-sm last:border-b-0\"\r\n\t\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t\t<span class=\"text-muted-foreground\"\r\n\t\t\t\t\t\t\t\t\t\t>{featureLabels[featureKey]}</span\r\n\t\t\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t\t{#if typeof value === \"boolean\"}\r\n\t\t\t\t\t\t\t\t\t\t{#if value}\r\n\t\t\t\t\t\t\t\t\t\t\t<Check class=\"size-4 text-primary\" />\r\n\t\t\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t\t\t<Minus class=\"size-4 text-muted-foreground/50\" />\r\n\t\t\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t\t\t{:else}\r\n\t\t\t\t\t\t\t\t\t\t<span class=\"font-medium text-foreground\">{value}</span>\r\n\t\t\t\t\t\t\t\t\t{/if}\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t{/each}\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</Card>\r\n\t\t\t{/each}\r\n\t\t</div>\r\n\t</div>\r\n</section>\r\n",
			"type": "registry:component",
			"target": "veil/comparator/comparator-three.svelte"
		}
	]
}