{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "veil-footer-four",
  "type": "vfooter",
  "description": "Veil Footer component, variant Four.",
  "registryDependencies": [],
  "dependencies": [],
  "devDependencies": [
    {
      "ecosystem": "js",
      "name": "@lucide/svelte",
      "version": "^0.561.0"
    },
    {
      "ecosystem": "js",
